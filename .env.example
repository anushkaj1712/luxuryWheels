# =============================================================================
# DRIVE LUXURY WHEELS — Root environment (copy to `.env` at repo root)
# =============================================================================
# One file for local dev: copy this file to `.env` in the same folder as
# package.json. Both the frontend (Next.js) and backend (Express) load it.
# Optional: you can still use `backend/.env` or `frontend/.env.local` to override.
# =============================================================================

# --- Shared URLs (Vercel + Render) ---
# Vercel: set NEXT_PUBLIC_* in Project → Settings → Environment Variables.
# Render API: set CLIENT_URL to your exact Vercel origin (https://…).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
CLIENT_URL=http://localhost:3000

# Optional: comma-separated extra CORS origins (Vercel preview URLs, staging).
# CORS_ORIGINS=https://your-app-git-branch-team.vercel.app

# --- Backend ---
NODE_ENV=development
PORT=5000

# Logging: debug | info | warn | error (Render: use "info" or "warn")
# LOG_LEVEL=info

# Request timeout for Express (ms)
# API_REQUEST_TIMEOUT_MS=30000

# PostgreSQL (Supabase or Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

JWT_SECRET=replace_with_strong_random_secret_minimum_32_characters
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Drive Luxury Wheels <noreply@yourdomain.com>"

# Optional: hide the small “showcase dataset” ribbon (defaults visible when API URL is absent)
# NEXT_PUBLIC_HIDE_DEMO_RIBBON=1

# Optional: WhatsApp deep link for concierge CTAs in demo / offline flows
# NEXT_PUBLIC_DEMO_WHATSAPP_URL=https://wa.me/919000000000
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
