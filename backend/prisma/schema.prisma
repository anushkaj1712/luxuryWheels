// =============================================================================
// DRIVE LUXURY WHEELS — Prisma schema (PostgreSQL)
// =============================================================================
// After cloning:
// 1) Copy `.env.example` to `.env` and set DATABASE_URL (Supabase/Neon/local).
// 2) Run: npx prisma migrate dev --name init
// 3) Run: npx prisma generate
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums — keep domain values in the database for integrity & reporting
// -----------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  PLUGIN_HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  DCT
}

enum BookingStatus {
  PENDING_PAYMENT
  RESERVED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum NotificationType {
  BOOKING
  PAYMENT
  SYSTEM
  MARKETING
}

// -----------------------------------------------------------------------------
// User — customer accounts (JWT auth). Admins use role on same table.
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String? // null when using Google OAuth only
  name          String
  phone         String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false)
  googleId      String?   @unique
  otpCode       String? // short-lived email OTP (hashed in production recommended)
  otpExpiresAt  DateTime?
  resetToken    String?
  resetExpires  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
  payments      Payment[]
  reviews       Review[]
  wishlists     Wishlist[]
  testDrives    TestDrive[]
  notifications Notification[]
  inquiries     Inquiry[]

  @@index([email])
  @@index([role])
}

// -----------------------------------------------------------------------------
// Admin — extended profile for staff (optional 1:1 with User when role=ADMIN)
// -----------------------------------------------------------------------------

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String?
  permissions Json? // fine-grained feature flags JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Note: link to User in application layer via userId (Prisma relation optional)
}

// -----------------------------------------------------------------------------
// Car + media
// -----------------------------------------------------------------------------

model Car {
  id             String             @id @default(cuid())
  slug           String             @unique
  brand          String
  model          String
  year           Int
  price          Decimal            @db.Decimal(12, 2)
  mileage        Int
  fuel           FuelType
  transmission   TransmissionType
  engine         String?
  horsepower     Int?
  torqueNm       Int?
  color          String?
  description    String             @db.Text
  features       String[] // simple feature tags; rich JSON can replace later
  vin            String?            @unique
  locationCity   String?
  locationLat    Float?
  locationLng    Float?
  isFeatured     Boolean            @default(false)
  isAvailable    Boolean            @default(true)
  brochureUrl    String? // Cloudinary or static PDF
  videoUrl       String? // showcase / hero clip
  model3dUrl     String? // GLB/USDZ path for 3D viewer
  metaTitle      String?
  metaDescription String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  images    CarImage[]
  bookings  Booking[]
  reviews   Review[]
  wishlists Wishlist[]
  testDrives TestDrive[]

  @@index([brand, model])
  @@index([price])
  @@index([year])
  @@index([isFeatured])
  @@index([isAvailable])
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  is360     Boolean  @default(false) // mark frames for 360 viewer
  createdAt DateTime @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

// -----------------------------------------------------------------------------
// Booking + Payment (token / reservation flow)
// -----------------------------------------------------------------------------

model Booking {
  id            String        @id @default(cuid())
  userId        String
  carId         String
  status        BookingStatus @default(PENDING_PAYMENT)
  tokenAmount   Decimal       @db.Decimal(12, 2)
  currency      String        @default("INR")
  receiptNumber String?       @unique
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  car      Car       @relation(fields: [carId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([userId])
  @@index([carId])
  @@index([status])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  bookingId         String?
  provider          PaymentProvider
  providerPaymentId String?         @unique // Stripe PI id or Razorpay payment id
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("INR")
  status            PaymentStatus   @default(PENDING)
  rawPayload        Json? // gateway response snapshot for audits
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Reviews, wishlist, test drives
// -----------------------------------------------------------------------------

model Review {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  rating    Int // 1-5
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@index([carId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@index([userId])
}

model TestDrive {
  id          String   @id @default(cuid())
  userId      String
  carId       String
  preferredAt DateTime
  message     String?  @db.Text
  status      String   @default("REQUESTED") // REQUESTED | SCHEDULED | DONE | CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car  Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([carId])
}

// -----------------------------------------------------------------------------
// Blog
// -----------------------------------------------------------------------------

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  blogs Blog[]
}

model Blog {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  excerpt        String?
  contentHtml    String   @db.Text // sanitized HTML from admin editor
  coverImageUrl  String?
  published      Boolean  @default(false)
  readingMinutes Int?
  categoryId     String?
  authorId       String? // optional link to admin user id string
  metaTitle      String?
  metaDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([published])
  @@index([categoryId])
}

// -----------------------------------------------------------------------------
// Inquiries & contact
// -----------------------------------------------------------------------------

model Inquiry {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  source    String? // page path / campaign
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([email])
}

// -----------------------------------------------------------------------------
// Testimonials (homepage) & notifications
// -----------------------------------------------------------------------------

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  avatarUrl String?
  quote     String   @db.Text
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String           @db.Text
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
